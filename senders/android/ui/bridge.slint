// bridge.slint — AppState enum and Bridge global singleton.
// Single source of truth for all properties and callbacks shared between
// Slint UI and Rust backend.
//
// Re-exported from main.slint so that slint_build::compile("ui/main.slint")
// exposes Bridge and AppState to Rust via ui.global::<Bridge>().
//
// Slint docs ref (globals): draft/slint/docs/astro/src/content/docs/guide/language/coding/globals.mdx
// Slint docs ref (enums):   draft/slint/docs/astro/src/content/docs/guide/language/coding/structs-and-enums.mdx

export enum LifecycleMode {
    normal,
    lock-screen,
    stealth,
    snapshot-countdown,
}

export enum AppState {
    Disconnected,
    Connecting,
    SelectingSettings,
    WaitingForMedia,
    Casting,
}

export enum Panel {
    none,
    settings,
    debug,
    codec-test,
    audio,
    quick-actions,
    bitrate-presets,
    bitrate-preset-edit,
    network,
}

export struct QuickAction {
    id:      string,
    title:   string,
    enabled: bool,
    active:  bool,
}

export enum StatusSeverity { info, warning, error }

export struct StatusItem {
    label:    string,
    value:    string,
    severity: StatusSeverity,
}

export struct ReceiverItem {
    name:    string,
    address: string,
}

export struct BitratePreset {
    id:           string,
    name:         string,
    bitrate-kbps: int,
    active:       bool,
}

export struct NetworkInterface {
    name:        string,
    kind:        string,    // "wifi" / "ethernet" / "cellular" / "loopback"
    address-v4:  string,
    address-v6:  string,
    enabled:     bool,
}

export global Bridge {
    // ── Data properties (Rust → Slint) ──────────────────────────────────
    in property <[string]> devices: [
        // "Device 1", "Device 2",
    ];
    in-out property <AppState> app-state: AppState.Disconnected;
    in-out property <Panel>    active-panel: Panel.none;
    in-out property <LifecycleMode> lifecycle: LifecycleMode.normal;
    in-out property <int> mock-snapshot-secs: 5;
    in-out property <bool>     show-debug: false;
    in-out property <string>   test-status: "";
    in property <[QuickAction]> quick-actions: [];

    // ── Callbacks (Slint → Rust) ─────────────────────────────────────────
    callback connect-receiver(string);
    callback start-casting(scale-width: int, scale-height: int, max-framerate: int);
    callback stop-casting();
    callback invoke-action(string);

    // ── Public functions (callable from Slint) ───────────────────────────
    public function change-state(to: AppState) {
        Bridge.app-state = to;
    }
}
