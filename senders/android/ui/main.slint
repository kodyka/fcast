// main.slint — Thin root file compiled by slint_build::compile("ui/main.slint").
//
// Responsibilities:
//   1. Re-export Bridge and AppState from bridge.slint so slint_build generates
//      the correct Rust bindings and ui.global::<Bridge>() resolves at runtime.
//   2. Import all page components.
//   3. Declare MainWindow and route AppState to the correct page.
//
// Per Slint module docs (re-export syntax):
//   export { X } from "other.slint"   — brings X into scope AND re-exports it.
//   No separate `import` of the same name is needed after a re-export.
//   Source: draft/slint/docs/astro/src/content/docs/guide/language/coding/file.mdx
//
// All UI logic lives in the imported modules:
//   bridge.slint          — AppState enum + Bridge global
//   theme.slint           — design tokens (stub, populated Phase 2)
//   pages/connect_page    — ConnectView
//   pages/connecting_page — ConnectingView
//   pages/settings_page   — SettingsPageView
//   pages/casting_page    — WaitingForMediaView, CastingView
//   pages/debug_page      — DebugPage (used inside connect_page)
//   components/*          — shared components (stubs, populated Phase 3–5)

// ── Re-export Bridge + AppState for the Rust backend ─────────────────────────
// This single line both makes Bridge/AppState available within this file AND
// exposes them to native code via the compiled Slint bindings.
export { Bridge, AppState } from "bridge.slint";

// ── Page component imports ────────────────────────────────────────────────────
import { ConnectView }                   from "pages/connect_page.slint";
import { ConnectingView }               from "pages/connecting_page.slint";
import { SettingsPageView }             from "pages/settings_page.slint";
import { WaitingForMediaView,
         CastingView }                  from "pages/casting_page.slint";

// ── Root window ───────────────────────────────────────────────────────────────
export component MainWindow inherits Window {
    // Conditional elements: only the matching view is instantiated.
    // Slint docs: https://releases.slint.dev/1.15.1/docs  (Conditional Elements)
    if Bridge.app-state == AppState.Disconnected:      ConnectView { }
    if Bridge.app-state == AppState.Connecting:        ConnectingView { }
    if Bridge.app-state == AppState.SelectingSettings: SettingsPageView { }
    if Bridge.app-state == AppState.WaitingForMedia:   WaitingForMediaView { }
    if Bridge.app-state == AppState.Casting:           CastingView { }
}
