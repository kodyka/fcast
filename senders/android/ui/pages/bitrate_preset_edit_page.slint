// bitrate_preset_edit_page.slint — Single-preset editor.
//
// Reachable from BitratePresetsPage's "Add preset" button (and, in a
// future phase, from per-row edit affordances). Cancel returns to the
// list without persisting; Save calls `Bridge.save-preset(...)` and
// returns to the list. When `Bridge.selected-preset-id == ""` the
// callback creates a new preset (Rust assigns the id).
//
// Phase 8 / Cluster C1: persistence is owned by Rust via
// `Bridge.save-preset`.
//
// Slint docs ref:
//   draft/slint-ui/docs/astro/src/content/docs/reference/std-widgets/views/lineedit.mdx
//   draft/slint-ui/docs/astro/src/content/docs/reference/std-widgets/basic-widgets/slider.mdx

import { ScrollView, LineEdit } from "std-widgets.slint";
import { Bridge, Panel } from "../bridge.slint";
import { Theme } from "../theme.slint";
import { TextButton } from "../components/buttons.slint";
import {
    SettingsSection,
    SettingsSliderRow,
} from "../components/settings_rows.slint";

export component BitratePresetEditPage inherits Rectangle {
    // ── Local draft state ───────────────────────────────────────────────
    // Kept page-local so Cancel can drop the partial edits without
    // touching Bridge.presets. Save flushes via `Bridge.save-preset`.
    in-out property <string> draft-name:         "New preset";
    in-out property <float>  draft-bitrate-kbps: 4000.0;

    width: 100%;
    height: 100%;
    background: Theme.surface-primary;

    VerticalLayout {
        // ── Header ──────────────────────────────────────────────────────
        Rectangle {
            height: 56px;
            background: Theme.surface-card;
            HorizontalLayout {
                padding: Theme.padding-screen;
                spacing: Theme.spacing-default;
                TextButton {
                    label: @tr("dismiss-dialog-button" => "Cancel");
                    // Return to the LIST, not the cast screen.
                    clicked => { Bridge.active-panel = Panel.bitrate-presets; }
                }
                Text {
                    text: @tr("Edit preset");
                    color: Theme.text-primary;
                    font-size: Theme.font-size-heading;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                    horizontal-stretch: 1;
                }
                TextButton {
                    label: @tr("save-button" => "Save");
                    clicked => {
                        Bridge.save-preset(
                            Bridge.selected-preset-id,
                            root.draft-name,
                            // Slider value is a float; the callback wants int.
                            // Round to the nearest integer kbps.
                            round(root.draft-bitrate-kbps),
                        );
                        Bridge.active-panel = Panel.bitrate-presets;
                    }
                }
            }
        }

        ScrollView {
            mouse-drag-pan-enabled: true;
            VerticalLayout {
                spacing: Theme.spacing-default;
                padding: Theme.padding-screen;

                SettingsSection {
                    title: @tr("NAME");
                    Rectangle {
                        height: 56px;
                        HorizontalLayout {
                            padding-left:  Theme.padding-screen;
                            padding-right: Theme.padding-screen;
                            LineEdit {
                                placeholder-text: @tr("Preset name");
                                text <=> root.draft-name;
                                horizontal-stretch: 1;
                            }
                        }
                    }
                }

                SettingsSection {
                    title: @tr("BITRATE");
                    SettingsSliderRow {
                        title: @tr("Bitrate");
                        unit: " kbps";
                        minimum: 500;
                        maximum: 20000;
                        value <=> root.draft-bitrate-kbps;
                        // Domain matches storage; `<=>` is safe.
                    }
                }
            }
        }
    }
}